DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

MYSQL_NAME=adornbysoc
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_PASS
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Shopify — sirf ye 2 values chahiye (checkout + product sync dono ke liye)
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
# Storefront token: Sales channels > Headless > Manage > Storefront API
SHOPIFY_STOREFRONT_ACCESS_TOKEN=public_token_xxx

# OPTIONAL (sirf instant webhook auto-sync ke liye; warna cron kaafi hai):
# Dev Dashboard app ka Admin token + API secret
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
# SHOPIFY_WEBHOOK_SECRET=xxx
