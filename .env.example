DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

MYSQL_NAME=adornbysoc
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_PASS
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Shopify — PATTERN: Django dashboard = master.
# Dashboard save -> Shopify push -> website live.
# Website order (Shopify checkout) -> Shopify + Django dashboard dono me.
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
# Storefront token (checkout): Sales channels > Headless > Manage > Storefront API
SHOPIFY_STOREFRONT_ACCESS_TOKEN=public_token_xxx

# Admin token (REQUIRED — dashboard->Shopify push + orders pull):
# Dev Dashboard app, scopes: read/write_products, read/write_inventory, read_orders
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
# Webhook secret (orders instantly in dashboard); cron backup: sync_shopify_orders
SHOPIFY_WEBHOOK_SECRET=xxx
# Public site URL (image push base in production)
SITE_URL=https://www.adornbysoc.com
